<?xml version="1.0" encoding="utf-8"?>
<!--
    Chameleon data extraction rules.
    allowBackup is false in manifest — this file is belt-and-suspenders.
    NO data may be backed up to Google Drive or other cloud services.
    This prevents IFR cache, encryption keys, and rules from leaking.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
